{
  "version": 2,
  "builds": [
    {
      "src": "backend/server.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/server.js"
    },
    {
      "src": "/css/(.*)",
      "dest": "frontend/css/$1"
    },
    {
      "src": "/js/(.*)",
      "dest": "frontend/js/$1"
    },
    {
      "src": "/pages/(.*)",
      "dest": "frontend/pages/$1"
    },
    {
      "src": "/capture",
      "dest": "backend/server.js"
    },
    {
      "src": "/notes",
      "dest": "backend/server.js"
    },
    {
      "src": "/learn",
      "dest": "backend/server.js"
    },
    {
      "src": "/quiz",
      "dest": "backend/server.js"
    },
    {
      "src": "/summary",
      "dest": "backend/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "backend/server.js"
    }
  ]
}
